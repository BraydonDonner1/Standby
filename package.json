{
  "name": "standby",
  "version": "1.0.0",
  "description": "Stream Deck / Bitfocus Companion-controllable cue light system for live production",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/index.js",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "lint": "eslint server/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0"
  },
  "build": {
    "appId": "cc.crchurch.standby",
    "productName": "Standby",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "electron/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/**/*",
      "config.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "config.json",
        "to": "config.json"
      }
    ]
  }
}
